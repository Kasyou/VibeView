#!/usr/bin/env bash
# VibeView Stop hook — pushes Claude's last response to the whiteboard
set -euo pipefail

PORT="${VIBEVIEW_PORT:-51820}"

# Only run if whiteboard is up
if ! curl -s --connect-timeout 1 "http://localhost:${PORT}/health" > /dev/null 2>&1; then
    exit 0
fi

# Confirm it's Claude mode
mode=$(curl -s --connect-timeout 1 "http://localhost:${PORT}/api/config" | python3 -c "import json,sys; print(json.load(sys.stdin).get('mode',''))" 2>/dev/null)
if [ "$mode" != "claude" ]; then
    exit 0
fi

# Find the session JSONL (most recently modified)
SESSION_DIR="$HOME/.claude/projects"
LATEST=$(find "$SESSION_DIR" -name "*.jsonl" -printf "%T@ %p\n" 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2)
if [ -z "$LATEST" ] || [ ! -f "$LATEST" ]; then
    exit 0
fi

# Extract last assistant text and push
python3 -c "
import json, urllib.request

with open('${LATEST}', encoding='utf-8') as f:
    lines = f.readlines()

last_text = ''
for line in reversed(lines):
    try: d = json.loads(line.strip())
    except: continue
    if d.get('type') == 'assistant':
        for c in d.get('message',{}).get('content',[]):
            if isinstance(c,dict) and c.get('type')=='text':
                last_text = c['text']
                break
    if last_text:
        break

if not last_text:
    exit()

# Extract title from first ## or first sentence
title = 'Claude'
for line in last_text.split('\n'):
    if line.strip().startswith('## '):
        title = line.strip()[3:][:80]
        break
if title == 'Claude':
    first = last_text.split('.')[0].strip()
    if len(first) > 10:
        title = first[:80]

# Dedup: skip if same as last push
import os, hashlib
h = hashlib.md5(last_text.encode()).hexdigest()
hash_file = os.path.expanduser('~/.vibeview-last-hash')
try:
    with open(hash_file) as f:
        if f.read().strip() == h:
            exit()
except: pass
with open(hash_file, 'w') as f:
    f.write(h)

# Push
data = json.dumps({'title': title, 'content': last_text[:2000]}, ensure_ascii=False).encode('utf-8')
req = urllib.request.Request(f'http://localhost:${PORT}/api/show', data=data, headers={'Content-Type': 'application/json; charset=utf-8'}, method='POST')
urllib.request.urlopen(req, timeout=5)
" 2>/dev/null || true

exit 0
